<!DOCTYPE html>
<html lang="en">
  <head>
    {% block head %}
      <meta charset="UTF-8" />
      <meta http-equiv="X-UA-Compatible" content="IE=edge" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />

      {% assets "../tailwind.css", output="tailwind.css" %}
        <link rel="stylesheet" href="{{ ASSET_URL }}" />
      {% endassets %}

      <script src="/static/temporal.js"></script>

      <link rel="icon" href="data:image/png;base64,iVBORw0KGgo=" />

      <title>
        {% block fulltitle %}{% block title %}{% endblock title %} — Fantasy TF2{% endblock fulltitle %}
      </title>
    {% endblock head %}
  </head>

  <body class="bg-blue-100">
    <header class="mx-auto mt-4 mb-12 flex max-w-3xl items-baseline">
      <a href="{{ url_for('homepage') }}" class="flex-5 text-5xl"
        >Fantasy TF2</a
      >

      {% if me is not none %}
        <a
          href="{{ url_for('manager', id=me.manager_id) }}"
          class="mx-auto flex-1 hover:underline"
          >My Profile</a
        >

        <a href="{{ url_for('logout') }}" class="mx-auto flex-1 hover:underline"
          >Sign out</a
        >
      {% else %}
        <a
          href="{{ url_for('login') }}"
          class="mx-auto flex-2 text-green-700 hover:bg-green-500"
        >
          Sign in through STEAM&reg;
          {# <img src="https://community.fastly.steamstatic.com/public/images/signinthroughsteam/sits_01.png" /> #}
        </a>
      {% endif %}
    </header>

    <main class="mx-auto max-w-5xl">{% block main %}{% endblock main %}</main>

    <footer class="mx-auto mt-12 mb-4 flex justify-center">
      <a
        href="https://tf2.spot"
        class="text-sm text-stone-500/30 hover:text-stone-500/90 hover:underline"
        >a tf2.spot project</a
      >
    </footer>
  </body>
</html>
