<!DOCTYPE html>
<html lang="en">
  <head>
    {% block head %}
      <meta charset="UTF-8" />
      <meta http-equiv="X-UA-Compatible" content="IE=edge" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />

      {% assets "../tailwind.css", output="tailwind.css" %}
        <link rel="stylesheet" href="{{ ASSET_URL }}" />
      {% endassets %}

      {% assets "../temporal.js", output="temporal.js" %}
        <script src="{{ ASSET_URL }}"></script>
      {% endassets %}

      <link rel="icon" href="data:image/png;base64,iVBORw0KGgo=" />

      <title>
        {% block fulltitle %}{% block title %}{% endblock %} — Fantasy TF2{% endblock %}
      </title>
    {% endblock head %}
  </head>

  <body class="bg-blue-100">
    <header
      class="mx-auto mt-4 mb-12 flex max-w-3xl items-baseline justify-between"
    >
      <a href="{{ url_for('homepage') }}" class="text-5xl">Fantasy TF2</a>

      <a
        href="{{ url_for('my_profile') }}"
        class="rounded px-4 py-2 hover:bg-blue-300/50 hover:underline"
      >
        My Profile
      </a>
    </header>

    <main class="mx-auto max-w-5xl">{% block main %}{% endblock %}</main>

    <footer class="mt-12 mb-4 flex justify-center">
      <a
        href="https://tf2.spot"
        class="text-sm text-stone-500/30 hover:text-stone-500/90 hover:underline"
        >a tf2.spot project</a
      >
    </footer>
  </body>
</html>
