<!DOCTYPE html>
<html lang="en">

<head>
  {% block head %}
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  {% assets "../tailwind.css", output="tailwind.css" %}
    <link rel="stylesheet" href="{{ ASSET_URL }}" />
  {% endassets %}

  <title>{% block fulltitle %}{% block title %}{% endblock title %} — Fantasy TF2{% endblock fulltitle %}</title>

  {% endblock head %}
</head>

<body class="bg-blue-100">
  <header>
    <a href="{{ url_for('homepage') }}">Fantasy TF2</a>
    {% if me is not none %}
    <a href="{{ url_for('profile', id=me.manager_id) }}">My Profile</a>
    <a href="{{ url_for('logout') }}">Sign out</a>
    {% else %}
    <a href="{{ url_for('login') }}">
      <img src="https://community.fastly.steamstatic.com/public/images/signinthroughsteam/sits_01.png" />
    </a>
    {% endif %}
  </header>
  
  <main>
    {% block body %}{% endblock body %}
  </main>
</body>
</html>
