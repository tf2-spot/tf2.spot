{% extends "base.jinja" %}

{% block title %}Manage{% endblock %}

{% block main %}
  <div class="grid gap-4 md:grid-cols-2">
    <div class="bg-gray-100 p-4 dark:bg-red-900">
      {% for fantasy in tournament.my_fantasy %}
        <p>Current roster</p>
        {% for contract in fantasy.contract %}
          <pre>{{ contract | tojson(2) }}</pre>
        {% endfor %}
      {% else %}
        No active roster
      {% endfor %}
    </div>

    <div class="flex flex-col gap-4 bg-gray-100 p-4 dark:bg-red-900">
      <p>Desired roster</p>
      {% set participants = tournament.participant %}
      {% include "partial/desired.jinja" %}

      <div>
        <form method="post">
          <input type="hidden" name="reset" value="" />
          <button
            class="rounded bg-blue-800/75 px-4 py-2 text-white shadow-lg hover:bg-blue-800/90 dark:bg-red-700/75 hover:dark:bg-red-700/90"
          >
            Reset
          </button>
        </form>
      </div>

      <div>
        <form method="post" class="flex justify-between">
          <button
            class="rounded bg-blue-800/75 px-4 py-2 text-white shadow-lg hover:bg-blue-800/90 dark:bg-red-700/75 hover:dark:bg-red-700/90"
          >
            Add
          </button>
          <select name="add" class="px-2 shadow-sm">
            <option value="" selected disabled>Pick a player</option>
            {% for participant in participants %}
              <option value="{{ participant.id }}">
                {{ participant.team.tag or participant.team.name }}
                {{ participant.name }}
                ({{ participant.main_class | capitalize }}
                {{ participant.price | currencyformat("USD") }})
              </option>
            {% endfor %}
          </select>
        </form>
      </div>

      <div>
        <form method="post">
          <input type="hidden" name="commit" value="" />
          <button
            class="w-full rounded bg-blue-800/75 py-2 text-lg font-bold text-white uppercase shadow-lg hover:bg-blue-800/90 dark:bg-red-700/75 hover:dark:bg-red-700/90"
          >
            Commit roster
          </button>
        </form>
      </div>
    </div>
  </div>

  <pre class="text-xs">{{ tournament | tojson(2) }}</pre>
{% endblock %}
